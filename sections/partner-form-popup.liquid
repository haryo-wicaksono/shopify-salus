{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign bg_color = false
  if color_scheme == 'default'
    assign bg_color = settings.bg_color
  elsif color_scheme == '1'
    assign bg_color = settings.color_scheme_1_bg_grad | default: settings.color_scheme_1_bg
  elsif color_scheme == '2'
    assign bg_color = settings.color_scheme_2_bg_grad | default: settings.color_scheme_2_bg
  elsif color_scheme == '3'
    assign bg_color = settings.color_scheme_3_bg_grad | default: settings.color_scheme_3_bg
  endif
  if bg_color == 'rgba(0,0,0,0)' or bg_color == settings.bg_color
    assign bg_color = false
  endif
-%}

<style>
  .partner-form-popup-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
  }

  #partner-contact-form .partner-form-popup-content::-webkit-scrollbar-thumb,
  #partner-contact-form .partner-form-popup-content::-webkit-scrollbar-track {
    border-radius: 100px;
  }

  #partner-contact-form .partner-form-popup-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: white;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    width: 100%;
    max-width: 900px;
    height: 100%;
    max-height: 600px;
    border-radius: 15px;
    overflow-y: auto;
    overflow-x: hidden;
    display: block;
    -webkit-overflow-scrolling: touch;
  }

  .partner-form-popup-close {
    position: absolute;
    top: 10px;
    right: 15px;
    font-size: 30px;
    cursor: pointer;
    z-index: 10;
  }

  .partner-form-popup-info {
    padding: 40px 50px;
    box-sizing: border-box;
  }

  .affiliate-popup-form__title {
    margin: 0 0 24px;
    font-family: Poppins, sans-serif;
    font-size: 32px;
    font-weight: 600;
    line-height: 42px;
    text-align: center;
    color: #000;
  }

  .affiliate-popup-form {
    padding: 0;
  }

  .affiliate-popup-form__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 20px;
    row-gap: 15px;
  }

  .affiliate-popup-form__field--full {
    grid-column: 1 / -1;
  }

  .affiliate-popup-form label {
    display: block;
    font-size: 14px;
    font-weight: 400;
    margin-bottom: 6px;
    color: #000;
  }

  .affiliate-popup-form__label--required::after {
    content: '*';
    color: red;
    margin-left: 2px;
  }

  .affiliate-popup-form input[type='text'],
  .affiliate-popup-form input[type='email'],
  .affiliate-popup-form input[type='tel'],
  .affiliate-popup-form input[type='url'] {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ccc;
    border-radius: 0.5rem;
    box-sizing: border-box;
    font-size: 15px;
  }

  .affiliate-popup-form__terms {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 2px;
  }

  .affiliate-popup-form__terms input {
    width: auto;
    margin-top: 3px;
  }

  .affiliate-popup-form__terms label {
    margin: 0;
    font-size: 13px;
    font-weight: 400;
  }

  .affiliate-popup-form__terms a {
    color: inherit;
    text-decoration: underline;
  }

  .affiliate-popup-form__submit {
    width: 100%;
    margin-top: 20px;
    padding: 15px 20px;
    border-radius: 100px;
    border: 1px solid #222120;
    background: #222120 !important;
    color: #fff;
    font-family: Poppins, sans-serif !important;
    font-size: 21px;
    font-weight: 500;
    line-height: 31.5px;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }

  .affiliate-popup-form__submit:hover {
    color: #000;
    background: #fff !important;
  }

  .affiliate-popup-form__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .affiliate-popup-form__status {
    margin-top: 12px;
    font-size: 14px;
    text-align: center;
    font-weight: 600;
  }

  .affiliate-popup-form__status.is-error {
    color: red;
  }

  .affiliate-popup-success {
    display: none;
    padding: 40px 0 0;
    text-align: center;
  }

  .affiliate-popup-success img {
    display: block;
    margin: 0 auto 16px;
    border-radius: 4px;
  }

  .affiliate-popup-success h2 {
    margin: 0 0 12px;
    font-family: Poppins, sans-serif;
    font-size: 32px;
    font-weight: 600;
    line-height: 42px;
  }

  .affiliate-popup-success p {
    margin: 0;
    color: #555;
    line-height: 1.6;
  }

  @media only screen and (max-width: 1024px) {
    #partner-contact-form .partner-form-popup-content {
      max-width: 900px;
    }
  }

  @media only screen and (max-width: 768px) {
    #partner-contact-form .partner-form-popup-content {
      max-height: 600px;
      max-width: 92%;
    }

    .partner-form-popup-info {
      padding: 20px;
    }

    .affiliate-popup-form__grid {
      grid-template-columns: 1fr;
    }

    .affiliate-popup-form__field--full {
      grid-column: auto;
    }

    .affiliate-popup-success {
      padding: 24px 0 0;
    }

    .affiliate-popup-success h2 {
      font-size: 28px;
      line-height: 36px;
    }

    .affiliate-popup-form__title {
      font-size: 28px;
      line-height: 36px;
    }
  }

  @media only screen and (max-width: 600px) {
    .partner-form-popup-info {
      padding: 30px;
      margin: 0;
      height: 100%;
      border-radius: 10px;
    }

    #partner-contact-form .partner-form-popup-content {
      border-radius: 10px;
    }

    .affiliate-popup-form__grid {
      grid-template-columns: 1fr;
      row-gap: 15px;
    }

    .affiliate-popup-form__submit {
      font-size: 14px;
      line-height: 21.5px;
    }

    .affiliate-popup-success h2 {
      font-size: 24px;
      line-height: 32px;
    }

    .affiliate-popup-form__title {
      font-size: 24px;
      line-height: 32px;
      margin-bottom: 20px;
    }
  }
</style>

<div id="partner-contact-form" class="partner-form-popup-overlay">
  <div class="partner-form-popup-content">
    <span id="partner-contact-form-close" class="partner-form-popup-close">&times;</span>
    <div class="partner-form-popup-info">
      <div class="affiliate-popup-form">
        <h2 class="affiliate-popup-form__title">{{ section.settings.heading }}</h2>
        <form id="affiliate-popup-form">
          <div class="affiliate-popup-form__grid">
            <div>
              <label for="affiliate-first-name" class="affiliate-popup-form__label--required">First Name</label>
              <input type="text" id="affiliate-first-name" required>
            </div>
            <div>
              <label for="affiliate-last-name" class="affiliate-popup-form__label--required">Last Name</label>
              <input type="text" id="affiliate-last-name" required>
            </div>

            <div class="affiliate-popup-form__field--full">
              <label for="affiliate-email" class="affiliate-popup-form__label--required">Email</label>
              <input type="email" id="affiliate-email" required>
            </div>

            <div class="affiliate-popup-form__field--full">
              <label for="affiliate-phone">Phone</label>
              <input type="tel" id="affiliate-phone" placeholder="+1 ">
            </div>

            <div class="affiliate-popup-form__field--full">
              <label for="affiliate-discount-code" class="affiliate-popup-form__label--required">{{ section.settings.discount_code_label }}</label>
              <input type="text" id="affiliate-discount-code" required>
            </div>

            <div class="affiliate-popup-form__field--full">
              <label for="affiliate-promo-link" class="affiliate-popup-form__label--required">{{ section.settings.promo_link_label }}</label>
              <input type="text" id="affiliate-promo-link" required inputmode="url" placeholder="this-is-cool.com">
            </div>

            <div class="affiliate-popup-form__field--full affiliate-popup-form__terms">
              <input type="checkbox" id="affiliate-terms" required>
              <label for="affiliate-terms">
                {{ section.settings.terms_label }}
                <a href="{{ section.settings.terms_url }}" target="_blank" rel="noopener">
                  {{- section.settings.terms_link_text -}}
                </a>
                *
              </label>
            </div>
          </div>

          <button type="submit" id="affiliate-submit-btn" class="btn btn--primary affiliate-popup-form__submit">
            {{ section.settings.submit_label }}
          </button>
          <div id="affiliate-form-status" class="affiliate-popup-form__status" aria-live="polite"></div>
        </form>
      </div>

      <div id="affiliate-success-message" class="affiliate-popup-success">
        <img
          src="https://cdn.shopify.com/s/files/1/0720/7695/1854/files/Untitled_design_8_8f855074-5aa9-4e83-8e9c-9705a8d522c3.png?v=1765890359"
          alt="{{ shop.name }}"
          width="120"
          loading="lazy"
        >
        <h2>{{ section.settings.success_heading }}</h2>
        <p>{{ section.settings.success_body }}</p>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const affiliateLinks = document.querySelectorAll('a[href="https://af.uppromote.com/salus-saunas-9974/register"]');
    const popup = document.getElementById('partner-contact-form');
    const closeBtn = document.getElementById('partner-contact-form-close');
    const form = document.getElementById('affiliate-popup-form');
        const submitBtn = document.getElementById('affiliate-submit-btn');
        const statusEl = document.getElementById('affiliate-form-status');
        const successEl = document.getElementById('affiliate-success-message');
    const formWrapper = popup ? popup.querySelector('.affiliate-popup-form') : null;
    const defaultSubmitLabel = {{ section.settings.submit_label | json }};
    const webhookUrl = {{ section.settings.webhook_url | json }};
    const resetPopupState = () => {
      if (!formWrapper || !successEl || !statusEl || !submitBtn) return;
      formWrapper.style.display = 'block';
      successEl.style.display = 'none';
      statusEl.textContent = '';
      statusEl.className = 'affiliate-popup-form__status';
      submitBtn.disabled = false;
      submitBtn.textContent = defaultSubmitLabel;
    };

    if (popup && closeBtn) {
      affiliateLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          resetPopupState();
          popup.style.display = 'block';
        });
      });

      closeBtn.addEventListener('click', () => {
        resetPopupState();
        popup.style.display = 'none';
      });

      popup.addEventListener('click', (e) => {
        if (e.target === popup) {
          resetPopupState();
          popup.style.display = 'none';
        }
      });
    }

    if (form && submitBtn && statusEl && successEl && formWrapper) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        if (!webhookUrl) {
          statusEl.textContent = 'Webhook URL is not configured.';
          statusEl.className = 'affiliate-popup-form__status is-error';
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        statusEl.textContent = '';
        statusEl.className = 'affiliate-popup-form__status';

        const formData = {
          promoLinkRaw: document.getElementById('affiliate-promo-link').value.trim(),
        };
        const normalizedPromoLink = formData.promoLinkRaw.match(/^https?:\/\//i)
          ? formData.promoLinkRaw
          : `https://${formData.promoLinkRaw}`;

        try {
          new URL(normalizedPromoLink);
        } catch (error) {
          statusEl.textContent = 'Please enter a valid promo link.';
          statusEl.className = 'affiliate-popup-form__status is-error';
          submitBtn.disabled = false;
          submitBtn.textContent = defaultSubmitLabel;
          return;
        }

        const payload = {
          firstName: document.getElementById('affiliate-first-name').value,
          lastName: document.getElementById('affiliate-last-name').value,
          email: document.getElementById('affiliate-email').value,
          phone: document.getElementById('affiliate-phone').value,
          discountCode: document.getElementById('affiliate-discount-code').value,
          promoLink: normalizedPromoLink,
          agreedToTerms: document.getElementById('affiliate-terms').checked,
        };

        try {
          const response = await fetch(webhookUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(`Request failed with status ${response.status}`);
          }

          form.reset();
          formWrapper.style.display = 'none';
          successEl.style.display = 'block';
        } catch (error) {
          console.error('Affiliate application error:', error);
          statusEl.textContent = 'Error sending application. Please try again.';
          statusEl.className = 'affiliate-popup-form__status is-error';
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = defaultSubmitLabel;
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Partner Form",
  "tag": "section",
  "class": "cc-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Become an affiliate"
    },
    {
      "type": "text",
      "id": "webhook_url",
      "label": "Webhook URL",
      "default": "https://salussaunas.app.n8n.cloud/webhook/nuevo-afiliado"
    },
    {
      "type": "text",
      "id": "discount_code_label",
      "label": "Discount code field label",
      "default": "Request your discount code:"
    },
    {
      "type": "text",
      "id": "promo_link_label",
      "label": "Promo link field label",
      "default": "Where you'll promote us (link): *"
    },
    {
      "type": "text",
      "id": "terms_label",
      "label": "Terms label prefix",
      "default": "I agree to the"
    },
    {
      "type": "text",
      "id": "terms_link_text",
      "label": "Terms link text",
      "default": "Terms & Conditions"
    },
    {
      "type": "text",
      "id": "terms_url",
      "label": "Terms URL",
      "default": "https://drive.google.com/file/d/1fIgj4S6KcnYfGv-oUjBjVAfUd4g3HxrP/view?usp=sharing"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Send for review"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success heading",
      "default": "Thank you for your application!"
    },
    {
      "type": "textarea",
      "id": "success_body",
      "label": "Success message",
      "default": "Your application is currently under review and will send an update via email in due course."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "1",
          "label": "Scheme 1"
        },
        {
          "value": "2",
          "label": "Scheme 2"
        },
        {
          "value": "3",
          "label": "Scheme 3"
        }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "Partner Form"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
