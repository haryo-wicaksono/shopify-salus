{%- if section.index > 2 -%}
  <link rel="stylesheet" href="{{ 'health-metrics-stats-grid.css' | asset_url }}" media="print" onload="this.media='all'">
{%- else -%}
  {{ 'health-metrics-stats-grid.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<div class="section health-metrics-stats-grid-section">
  <section
    class="health-metrics-stats-grid"
    id="health-metrics-stats-grid-{{ section.id }}"
    style="
      --health-metrics-stats-grid-desktop-min-height: {{ section.settings.desktop_section_height | default: 760 }}px;
      --health-metrics-stats-grid-mobile-min-height: {{ section.settings.mobile_section_height | default: 610 }}px;
    "
  >
    <div class="health-metrics-stats-grid__media">
      {%- if section.settings.background_image != blank -%}
        {% render 'image',
          image: section.settings.background_image,
          widths: '720, 960, 1200, 1440, 1800, 2200',
          src_width: 2200,
          src_placeholder: true,
          sizes: '100vw',
          class: 'health-metrics-stats-grid__image health-metrics-stats-grid__image--desktop img-fit img-fit--cover',
          disable_focal_point: true
        %}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'health-metrics-stats-grid__placeholder health-metrics-stats-grid__image--desktop' }}
      {%- endif -%}

      {%- if section.settings.mobile_background_image != blank -%}
        {% render 'image',
          image: section.settings.mobile_background_image,
          widths: '480, 640, 800, 960',
          src_width: 960,
          src_placeholder: true,
          sizes: '100vw',
          class: 'health-metrics-stats-grid__image health-metrics-stats-grid__image--mobile img-fit img-fit--cover',
          disable_focal_point: true
        %}
      {%- elsif section.settings.background_image != blank -%}
        {% render 'image',
          image: section.settings.background_image,
          widths: '480, 640, 800, 960',
          src_width: 960,
          src_placeholder: true,
          sizes: '100vw',
          class: 'health-metrics-stats-grid__image health-metrics-stats-grid__image--mobile img-fit img-fit--cover',
          disable_focal_point: true
        %}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'health-metrics-stats-grid__placeholder health-metrics-stats-grid__image--mobile' }}
      {%- endif -%}

      <div class="health-metrics-stats-grid__overlay health-metrics-stats-grid__overlay--desktop"></div>
      <div class="health-metrics-stats-grid__overlay health-metrics-stats-grid__overlay--mobile"></div>
    </div>

    <div class="container">
      <div class="health-metrics-stats-grid__inner">
        <div class="health-metrics-stats-grid__content">
          {%- if section.settings.eyebrow != blank -%}
            <p class="health-metrics-stats-grid__eyebrow">
              <span class="health-metrics-stats-grid__eyebrow-icon">
                <svg width="22" height="18" viewBox="0 0 22 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M7.37205 16.3802C4.25571 13.9924 0 10.048 0 6.31855C0 0.0879922 5.82394 -2.23841 10.589 2.57323C15.354 -2.23841 21.178 0.0879922 21.178 6.31855C21.178 10.048 16.9212 13.9924 13.8059 16.3802C12.3955 17.4603 11.6902 18.0014 10.589 18.0014C9.48773 18.0014 8.7825 17.4613 7.37205 16.3802ZM15.354 3.44152C15.5647 3.44152 15.7667 3.5252 15.9156 3.67413C16.0645 3.82307 16.1482 4.02507 16.1482 4.2357V5.55932H17.4718C17.6825 5.55932 17.8845 5.64299 18.0334 5.79193C18.1823 5.94087 18.266 6.14287 18.266 6.3535C18.266 6.56412 18.1823 6.76612 18.0334 6.91506C17.8845 7.064 17.6825 7.14767 17.4718 7.14767H16.1482V8.47129C16.1482 8.68192 16.0645 8.88392 15.9156 9.03286C15.7667 9.18179 15.5647 9.26547 15.354 9.26547C15.1434 9.26547 14.9414 9.18179 14.7925 9.03286C14.6435 8.88392 14.5599 8.68192 14.5599 8.47129V7.14767H13.2362C13.0256 7.14767 12.8236 7.064 12.6747 6.91506C12.5257 6.76612 12.4421 6.56412 12.4421 6.3535C12.4421 6.14287 12.5257 5.94087 12.6747 5.79193C12.8236 5.64299 13.0256 5.55932 13.2362 5.55932H14.5599V4.2357C14.5599 4.02507 14.6435 3.82307 14.7925 3.67413C14.9414 3.5252 15.1434 3.44152 15.354 3.44152Z" fill="#36C9BD"/>
                </svg>
              </span>
              <span>{{ section.settings.eyebrow | escape }}</span>
            </p>
          {%- endif -%}

          <h2 class="health-metrics-stats-grid__heading">
            <span class="health-metrics-stats-grid__heading-desktop">
              {{ section.settings.heading | escape | newline_to_br }}
            </span>
            <span class="health-metrics-stats-grid__heading-mobile">
              {{ section.settings.mobile_heading | default: section.settings.heading | escape | newline_to_br }}
            </span>
          </h2>

          {%- if section.blocks.size > 0 -%}
            <div class="health-metrics-stats-grid__metrics" role="list">
              {%- for block in section.blocks -%}
                <article
                  class="health-metrics-stats-grid__metric{% unless block.settings.show_on_mobile %} health-metrics-stats-grid__metric--desktop-only{% endunless %}"
                  role="listitem"
                  {{ block.shopify_attributes }}
                >
                  <div class="health-metrics-stats-grid__metric-circle">
                    {{ block.settings.value | escape }}
                  </div>

                  {%- if block.settings.label != blank -%}
                    <p class="health-metrics-stats-grid__metric-label">{{ block.settings.label | escape | newline_to_br }}</p>
                  {%- endif -%}
                </article>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Health Metrics Stats Grid",
  "tag": "section",
  "class": "cc-health-metrics-stats-grid",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Science-backed benefits"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Desktop heading",
      "default": "Old World Practice, Modern Day Proof"
    },
    {
      "type": "text",
      "id": "mobile_heading",
      "label": "Mobile heading",
      "info": "Optional. If blank, the desktop heading will be used."
    },
    {
      "type": "header",
      "content": "Background media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "Mobile background image",
      "info": "Optional. If blank, the desktop image is used."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_section_height",
      "label": "Desktop section min height",
      "min": 480,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "range",
      "id": "mobile_section_height",
      "label": "Mobile section min height",
      "min": 560,
      "max": 1300,
      "step": 10,
      "unit": "px",
      "default": 610
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "~40%"
        },
        {
          "type": "textarea",
          "id": "label",
          "label": "Label",
          "default": "Lower All-Cause\nMortality"
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on mobile",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Health Metrics Stats Grid",
      "settings": {
        "eyebrow": "Science-backed benefits",
        "heading": "Old World Practice, Modern Day Proof",
        "mobile_heading": "Old world practice\nModern day proof"
      },
      "blocks": [
        {
          "type": "metric",
          "settings": {
            "value": "~40%",
            "label": "Lower All-Cause\nMortality",
            "show_on_mobile": true
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "+32%",
            "label": "Increase in Time\nto Exhaustion",
            "show_on_mobile": true
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "~16x",
            "label": "In Growth\nHormone",
            "show_on_mobile": true
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "~70%",
            "label": "More Deep\nSleep",
            "show_on_mobile": true
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "~63%",
            "label": "Lower Risk of\nHeart Disease",
            "show_on_mobile": false
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "~66%",
            "label": "Lower Risk of\nDementia",
            "show_on_mobile": true
          }
        },
        {
          "type": "metric",
          "settings": {
            "value": "~33%",
            "label": "Lower Risk of\nBlood Clots",
            "show_on_mobile": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
