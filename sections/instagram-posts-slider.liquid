{%- if section.index > 2 -%}
  <link rel="stylesheet" href="{{ 'instagram-posts-slider.css' | asset_url }}" media="print" onload="this.media='all'">
{%- else -%}
  {{ 'instagram-posts-slider.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  assign account_url = section.settings.account_url | default: settings.social_instagram_url
  assign eyebrow_tag = 'div'
  if section.settings.link_eyebrow_to_account and account_url != blank
    assign eyebrow_tag = 'a'
  endif
-%}

<div class="section instagram-posts-slider-section">
  <div class="container">
    <div class="instagram-posts-slider">
      <div class="instagram-posts-slider__header">
        <{{ eyebrow_tag }}
          {% if eyebrow_tag == 'a' %}
            href="{{ account_url }}"
            target="_blank"
            rel="noopener"
          {% endif %}
          class="instagram-posts-slider__eyebrow"
        >
          <span class="instagram-posts-slider__eyebrow-icon">
            {% render 'icon-instagram' %}
          </span>
          <span>{{ section.settings.eyebrow | escape }}</span>
        </{{ eyebrow_tag }}>

        <h2 class="instagram-posts-slider__title">
          <span class="instagram-posts-slider__title-desktop">
            {{ section.settings.heading | escape }}
          </span>
          <span class="instagram-posts-slider__title-mobile">
            {{ section.settings.mobile_heading | default: section.settings.heading | escape }}
          </span>
        </h2>
      </div>

      {% if section.blocks.size > 0 %}
        <div class="instagram-posts-slider__viewport">
          <div class="instagram-posts-slider__track" role="list">
            {% for block in section.blocks %}
              {%- liquid
                assign card_tag = 'div'
                if block.settings.instagram_post_url != blank
                  assign card_tag = 'a'
                endif
              -%}
              <{{ card_tag }}
                {% if card_tag == 'a' %}
                  href="{{ block.settings.instagram_post_url }}"
                  target="_blank"
                  rel="noopener"
                {% endif %}
                class="instagram-posts-slider__card"
                role="listitem"
                aria-label="{% if block.settings.image != blank and block.settings.image.alt != blank %}{{ block.settings.image.alt | escape }}{% else %}Instagram post {{ forloop.index }}{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="instagram-posts-slider__media">
                  {%- if block.settings.image != blank -%}
                    {% render 'image',
                      image: block.settings.image,
                      widths: '320, 480, 640, 800',
                      src_width: 640,
                      src_placeholder: true,
                      sizes: '(max-width: 767px) 68vw, (min-width: 1280px) 280px, 25vw',
                      class: 'instagram-posts-slider__image instagram-posts-slider__image--desktop img-fit img-fit--cover',
                      disable_focal_point: true,
                      section_index: section.index
                    %}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'instagram-posts-slider__placeholder instagram-posts-slider__image--desktop' }}
                  {%- endif -%}

                  {%- if block.settings.mobile_image != blank -%}
                    {% render 'image',
                      image: block.settings.mobile_image,
                      widths: '240, 320, 480, 640',
                      src_width: 480,
                      src_placeholder: true,
                      sizes: '68vw',
                      class: 'instagram-posts-slider__image instagram-posts-slider__image--mobile img-fit img-fit--cover',
                      disable_focal_point: true,
                      section_index: section.index
                    %}
                  {%- elsif block.settings.image != blank -%}
                    {% render 'image',
                      image: block.settings.image,
                      widths: '240, 320, 480, 640',
                      src_width: 480,
                      src_placeholder: true,
                      sizes: '68vw',
                      class: 'instagram-posts-slider__image instagram-posts-slider__image--mobile img-fit img-fit--cover',
                      disable_focal_point: true,
                      section_index: section.index
                    %}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'instagram-posts-slider__placeholder instagram-posts-slider__image--mobile' }}
                  {%- endif -%}
                </div>
              </{{ card_tag }}>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <p class="instagram-posts-slider__empty">Add Instagram post cards to populate this section.</p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Instagram Posts Slider",
  "tag": "section",
  "class": "cc-instagram-posts-slider",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Desktop heading",
      "default": "Get the Latest Scoop on Saunas"
    },
    {
      "type": "text",
      "id": "mobile_heading",
      "label": "Mobile heading",
      "default": "Get the Latest Scoop on Saunas"
    },
    {
      "type": "url",
      "id": "account_url",
      "label": "Instagram account URL",
      "info": "Optional. Defaults to the global Instagram social link."
    },
    {
      "type": "checkbox",
      "id": "link_eyebrow_to_account",
      "label": "Link eyebrow to Instagram account",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "instagram_post",
      "name": "Instagram post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image",
          "info": "Optional. Falls back to the desktop image."
        },
        {
          "type": "url",
          "id": "instagram_post_url",
          "label": "Instagram post URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Posts Slider",
      "blocks": [
        {
          "type": "instagram_post"
        },
        {
          "type": "instagram_post"
        },
        {
          "type": "instagram_post"
        },
        {
          "type": "instagram_post"
        }
      ]
    }
  ]
}
{% endschema %}
