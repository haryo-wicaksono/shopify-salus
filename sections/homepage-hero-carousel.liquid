<script>
  // 1. Color Scheme Array (Original)
  const slideColorSchemes = [
    {% for block in section.blocks %}
      "{{ block.settings.color_scheme }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  // 2. NEW: Background Color Array (Custom > Dark > Default)
  const slideBackgroundColors = [
    {% for block in section.blocks %}
      {%- assign bg_color = section.settings.content_background_color -%}
      {%- if block.settings.color_scheme == 'dark' -%}
        {%- assign bg_color = '#222120' -%}
      {%- endif -%}
      {%- if block.settings.custom_content_bg != blank and block.settings.custom_content_bg != 'rgba(0,0,0,0)' -%}
        {%- assign bg_color = block.settings.custom_content_bg -%}
      {%- endif -%}
      "{{ bg_color }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  document.addEventListener('DOMContentLoaded', function() {
    const carouselElement = document.querySelector('.homepage-hero-carousel__swiper');

    function syncDesktopSlideHeights() {
      if (!carouselElement) return;

      const sectionEl = carouselElement.closest('.homepage-hero-carousel');
      if (!sectionEl) return;

      const headerGroup = document.querySelector('#shopify-section-header-group');
      const headerArea = headerGroup || document.querySelector('.cc-header');
      const headerHeight = headerArea ? headerArea.getBoundingClientRect().height : 0;
      sectionEl.style.setProperty('--homepage-hero-carousel-header-offset', `${Math.ceil(headerHeight)}px`);

      if (window.innerWidth <= 767) {
        sectionEl.style.removeProperty('--homepage-hero-carousel-desktop-height');
        return;
      }

      const slides = carouselElement.querySelectorAll('.homepage-hero-carousel__slide');
      let maxHeight = 550;

      slides.forEach((slide) => {
        const isFullBg = slide.classList.contains('homepage-hero-carousel__slide--full-background-centered');
        let slideHeight;

        if (isFullBg) {
          const contentCol = slide.querySelector('.homepage-hero-carousel__content-column--centered');
          slideHeight = contentCol ? contentCol.scrollHeight : slide.scrollHeight;
        } else {
          const contentColumn = slide.querySelector('.homepage-hero-carousel__content-column');
          slideHeight = contentColumn ? contentColumn.scrollHeight : slide.scrollHeight;
        }

        maxHeight = Math.max(maxHeight, slideHeight);
      });

      sectionEl.style.setProperty('--homepage-hero-carousel-desktop-height', `${Math.ceil(maxHeight)}px`);
    }

    // Original Pagination Logic
    function updatePaginationColor(swiper) {
      if (!swiper.el || !slideColorSchemes || typeof swiper.realIndex === 'undefined') return;

      const currentScheme = slideColorSchemes[swiper.realIndex];
      const sectionEl = carouselElement.closest('.homepage-hero-carousel');

      if (!sectionEl) return;

      if (currentScheme === 'dark') {
        sectionEl.classList.add('pagination-on-dark-slide');
      } else {
        sectionEl.classList.remove('pagination-on-dark-slide');
      }
    }

    // NEW: Helper to update wrapper background only
    function updateWrapperBackground(swiper) {
      if (!swiper.wrapperEl || !slideBackgroundColors || typeof swiper.realIndex === 'undefined') return;
      // We only set the color. Swiper's existing speed/transition handles the rest.
      swiper.wrapperEl.style.backgroundColor = slideBackgroundColors[swiper.realIndex];
    }

    if (carouselElement) {
      const swiper = new Swiper(carouselElement, {
        loop: {{ section.settings.enable_loop }},
        autoplay: {{ section.settings.enable_autoplay }} ? {
          delay: {{ section.settings.autoplay_speed }},
          disableOnInteraction: false,
        } : false,
        speed: 800,
        grabCursor: true,

        pagination: {
          el: '.homepage-hero-carousel__pagination',
          clickable: true,
        },

        navigation: {
          nextEl: '.carousel-arrow.arrow-right',
          prevEl: '.carousel-arrow.arrow-left',
        },
        a11y: {
          enabled: true,
          prevSlideMessage: 'Previous slide',
          nextSlideMessage: 'Next slide',
          firstSlideMessage: 'This is the first slide',
          lastSlideMessage: 'This is the last slide',
          paginationBulletMessage: '{% raw %}Go to slide {{index}}{% endraw %}',
        },

        // Use 'slideChange' and 'realIndexChange' for loop mode
        on: {
          init: function(swiper) {
            setTimeout(() => {
              syncDesktopSlideHeights();
              updatePaginationColor(swiper);
              updateWrapperBackground(swiper); // Added
            }, 0);
          },
          slideChange: function(swiper) {
            updatePaginationColor(swiper);
            updateWrapperBackground(swiper); // Added
          },
          realIndexChange: function(swiper) {
            updatePaginationColor(swiper);
            updateWrapperBackground(swiper); // Added
          }
        }
      });

      window.addEventListener('resize', syncDesktopSlideHeights);
      window.addEventListener('load', syncDesktopSlideHeights);
      setTimeout(syncDesktopSlideHeights, 150);
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const vDayBtn = document.querySelector('.homepage-hero-carousel__button--primary.vday-special');

    if (vDayBtn) {
      vDayBtn.addEventListener('click', function (e) {
        e.preventDefault();
        this.classList.add('is-popping');

        setTimeout(() => {
          window.location.href = this.getAttribute('href');
        }, 800);
      });
    }
  });
</script>

