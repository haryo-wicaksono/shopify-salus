{%- liquid
  assign feature_heading = panel_block.settings.feature_heading
  assign feature_cta_label = panel_block.settings.feature_cta_label
  assign feature_cta_url = panel_block.settings.feature_cta_url
  assign feature_image = panel_block.settings.feature_image
  assign feature_dark_mode = panel_block.settings.feature_dark_mode
  assign feature_text_color = panel_block.settings.feature_text_color
  assign feature_cta_pill_color = panel_block.settings.feature_cta_pill_color

  if feature_text_color == blank
    if feature_dark_mode
      assign feature_text_color = '#FFFFFF'
    else
      assign feature_text_color = '#222120'
    endif
  endif

  if feature_cta_pill_color == blank
    assign feature_cta_pill_color = 'transparent'
  endif

  assign feature_panel_tag = 'div'
  if feature_cta_url != blank
    assign feature_panel_tag = 'a'
  endif
-%}

{%- if feature_heading != blank or feature_image != blank or feature_cta_label != blank -%}
  <{{ feature_panel_tag }}
    {% if feature_cta_url != blank %}href="{{ feature_cta_url }}"{% endif %}
    class="desktop-gemini-feature-panel{% if feature_cta_url != blank %} desktop-gemini-feature-panel--link{% endif %}{% if feature_dark_mode %} desktop-gemini-feature-panel--dark{% endif %}"
    style="--desktop-gemini-feature-text-color: {{ feature_text_color }}; --desktop-gemini-feature-cta-pill-color: {{ feature_cta_pill_color }};"
  >
    <div class="desktop-gemini-feature-panel__media">
      {%- if feature_image != blank -%}
        {% render 'image',
          image: feature_image,
          src_width: 1200,
          srcset_2x: true,
          alt_text: feature_heading,
          class: 'img-fit'
        %}
      {%- endif -%}
    </div>
    <div class="desktop-gemini-feature-panel__overlay"></div>
    <div class="desktop-gemini-feature-panel__content">
      {%- if feature_heading != blank -%}
        <h2>{{- feature_heading -}}</h2>
      {%- endif -%}
      {%- if feature_cta_label != blank -%}
        <span class="desktop-gemini-feature-panel__cta">
          <span>{{- feature_cta_label -}}</span>
          {% render 'icon-arrow-right' %}
        </span>
      {%- endif -%}
    </div>
  </{{ feature_panel_tag }}>
{%- endif -%}
