{%- comment -%}
  Upcoming Product Popup (Singleton)
  This snippet should be rendered once in the layout.
{%- endcomment -%}
{%- assign google_script_url = 'https://script.google.com/macros/s/AKfycbxEJ7YSFtAxAC369i7McAQGKgRTZ6mJXRJit8kK_-gz738GUNzoA-CanPksCbPs0HwL5A/exec' -%}

<style>
  #popup-upcoming.custom-popup-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
  }
  #popup-upcoming .custom-popup-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: white;
    width: 90%;
    max-width: 800px;
    max-height: 90vh;
    border-radius: 15px;
    padding: 40px;
    overflow-y: auto;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  }
  #popup-upcoming .custom-popup-close {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 28px;
    cursor: pointer;
    z-index: 10;
  }
  /* Layout */
  #popup-upcoming .popup-layout {
    display: flex;
    gap: 40px;
  }
  #popup-upcoming .popup-left {
    flex: 1;
    text-align: center;
  }
  #popup-upcoming .popup-right {
    flex: 1.2;
    align-content: center;
  }

  /* Product Info */
  #popup-upcoming .popup-img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 15px;
    object-fit: cover;
    background-color: #fbf2e9;
  }
  #popup-upcoming h3 {
    margin: 10px 0 5px;
    font-size: 20px;
    font-weight: 600;
  }

  /* Form */
  #popup-upcoming h2 {
    margin-bottom: 20px;
    font-family: Poppins, sans-serif;
    font-size: 24px;
  }
  #popup-upcoming .custom-popup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  #popup-upcoming .custom-popup-full {
    grid-column: span 2;
  }
  #popup-upcoming input {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }
  #popup-upcoming button {
    width: 100%;
    padding: 15px;
    background: #222120;
    color: #fff;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    font-size: 18px;
    margin-top: 20px;
  }
  #popup-upcoming button:hover {
    background: #444;
  }
  #popup-upcoming .status-msg {
    margin-top: 15px;
    text-align: center;
    display: none;
  }
  .status-success {
    color: green;
  }
  .status-error {
    color: red;
  }

  @media (max-width: 768px) {
    #popup-upcoming .popup-layout {
      flex-direction: column;
      gap: 20px;
    }
    #popup-upcoming .popup-left {
      display: flex;
      gap: 15px;
      text-align: left;
      align-items: center;
    }
    #popup-upcoming .popup-img {
      width: 80px;
      height: 80px;
      margin-bottom: 0;
    }
    #popup-upcoming .custom-popup-grid {
      grid-template-columns: 1fr;
    }
    #popup-upcoming .custom-popup-full {
      grid-column: span 1;
    }
  }
</style>

<div id="popup-upcoming" class="custom-popup-overlay">
  <div class="custom-popup-content">
    <span id="close-upcoming" class="custom-popup-close">&times;</span>

    <div class="popup-layout">
      <!-- Left Column: Product Info -->
      <div class="popup-left">
        <img class="popup-img" src="" alt="" id="popup-upcoming-image">
        <h3 id="popup-upcoming-title"></h3>
      </div>

      <!-- Right Column: Form -->
      <div class="popup-right">
        <h2>Get Notified</h2>
        <form id="form-upcoming">
          <input type="hidden" name="form_type" value="Upcoming">
          <input type="hidden" name="product_id" value="" id="popup-upcoming-id">
          <input type="hidden" name="product_title" value="" id="popup-upcoming-title-hidden">
          <div style="display:none;"><input type="text" name="bot_check" autocomplete="off"></div>

          <div class="custom-popup-grid">
            <div><label>First Name</label><input type="text" name="first_name" required></div>
            <div><label>Last Name</label><input type="text" name="last_name" required></div>
            <div class="custom-popup-full"><label>Email</label><input type="email" name="email" required></div>
          </div>
          <button type="submit" id="btn-submit-upcoming">Get Notified</button>
          <div id="status-upcoming" class="status-msg"></div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const scriptURL = '{{ google_script_url }}';
    
    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('.js-btn-upcoming-trigger');
      if (trigger) {
        e.preventDefault();
        const productId = trigger.getAttribute('data-product-id');
        const productTitle = trigger.getAttribute('data-product-title');
        const productImage = trigger.getAttribute('data-product-image');

        document.getElementById('popup-upcoming-id').value = productId;
        document.getElementById('popup-upcoming-title').innerText = productTitle;
        document.getElementById('popup-upcoming-title-hidden').value = productTitle;
        document.getElementById('popup-upcoming-image').src = productImage;
        document.getElementById('popup-upcoming-image').alt = productTitle;

        document.getElementById('popup-upcoming').style.display = 'block';
      }

      if (e.target.id === 'close-upcoming' || e.target.id === 'popup-upcoming') {
        document.getElementById('popup-upcoming').style.display = 'none';
      }
    });

    const form = document.getElementById('form-upcoming');
    const status = document.getElementById('status-upcoming');
    const btn = document.getElementById('btn-submit-upcoming');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.innerText = 'Sending...';
        const data = Object.fromEntries(new FormData(form).entries());

        fetch(scriptURL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(data),
        })
          .then(() => {
            status.innerText = 'You are on the list!';
            status.className = 'status-msg status-success';
            status.style.display = 'block';
            form.reset();
            setTimeout(() => {
              document.getElementById('popup-upcoming').style.display = 'none';
              status.style.display = 'none';
            }, 3000);
          })
          .catch((err) => {
            console.error(err);
            status.innerText = 'Error. Please try again.';
            status.className = 'status-msg status-error';
            status.style.display = 'block';
          })
          .finally(() => {
            btn.disabled = false;
            btn.innerText = 'Get Notified';
          });
      });
    }
  })();
</script>
